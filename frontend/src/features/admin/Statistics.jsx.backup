import { useEffect, useState } from 'react'
import { Card, Row, Col, Statistic, Spin, Alert, Button, Typography, Divider } from 'antd'
import {
  UserOutlined,
  FileTextOutlined,
  ThunderboltOutlined,
  TeamOutlined,
  ReloadOutlined,
  DesktopOutlined,
} from '@ant-design/icons'
import { statsAPI } from '../../services/api'

const { Title, Text } = Typography

function Statistics() {
  const [stats, setStats] = useState(null)
  const [loading, setLoading] = useState(true)
  const [error, setError] = useState(null)
  const [lastUpdate, setLastUpdate] = useState(null)

  const fetchStats = async () => {
    try {
      setLoading(true)
      setError(null)
      const response = await statsAPI.get()
      setStats(response.data)
      setLastUpdate(new Date())
    } catch (err) {
      setError(err.response?.data?.detail || 'Failed to load statistics')
    } finally {
      setLoading(false)
    }
  }

  useEffect(() => {
    fetchStats()
  }, [])

  if (loading && !stats) {
    return (
      <div style={{ textAlign: 'center', padding: '100px 0' }}>
        <Spin size="large" tip="Loading statistics..." />
      </div>
    )
  }

  if (error) {
    return (
      <div style={{ padding: 24 }}>
        <Alert
          message="Failed to Load Statistics"
          description={error}
          type="error"
          showIcon
          action={
            <Button size="small" onClick={fetchStats}>
              Retry
            </Button>
          }
        />
      </div>
    )
  }

  if (!stats) return null

  const isSuperAdmin = stats.scope === 'platform'
  const title = isSuperAdmin ? 'Platform Statistics' : 'Organization Statistics'
  const subtitle = stats.tenant_name
    ? `Organization: ${stats.tenant_name}`
    : 'All Organizations'

  return (
    <div style={{ padding: 24 }}>
      <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: 24 }}>
        <div>
          <Title level={2} style={{ margin: 0 }}>
            {title}
          </Title>
          <Text type="secondary">{subtitle}</Text>
        </div>
        <div>
          {lastUpdate && (
            <Text type="secondary" style={{ marginRight: 16 }}>
              Last updated: {lastUpdate.toLocaleTimeString()}
            </Text>
          )}
          <Button icon={<ReloadOutlined />} onClick={fetchStats} loading={loading}>
            Refresh
          </Button>
        </div>
      </div>

      {/* Summary Cards */}
      <Row gutter={[16, 16]}>
        <Col xs={24} sm={12} lg={6}>
          <Card>
            <Statistic
              title="Total Users"
              value={stats.stats.users.total}
              prefix={<UserOutlined />}
              valueStyle={{ color: '#1890ff' }}
            />
            <div style={{ marginTop: 8 }}>
              <Text type="success">✓ {stats.stats.users.active} active</Text>
              <Divider type="vertical" />
              <Text type="secondary">✗ {stats.stats.users.inactive} inactive</Text>
            </div>
          </Card>
        </Col>

        <Col xs={24} sm={12} lg={6}>
          <Card>
            <Statistic
              title="Total Quizzes"
              value={stats.stats.quizzes.total}
              prefix={<FileTextOutlined />}
              valueStyle={{ color: '#1890ff' }}
            />
            <div style={{ marginTop: 8 }}>
              <Text type="success">✓ {stats.stats.quizzes.ready} ready</Text>
              <Divider type="vertical" />
              <Text type="warning">📝 {stats.stats.quizzes.draft} draft</Text>
            </div>
          </Card>
        </Col>

        <Col xs={24} sm={12} lg={6}>
          <Card>
            <Statistic
              title="Active Sessions"
              value={stats.stats.sessions.active}
              prefix={<ThunderboltOutlined />}
              valueStyle={{ color: stats.stats.sessions.active > 0 ? '#52c41a' : '#8c8c8c' }}
            />
            <div style={{ marginTop: 8 }}>
              <Text type="secondary">Today: {stats.stats.sessions.total_today}</Text>
              <Divider type="vertical" />
              <Text type="secondary">Total: {formatNumber(stats.stats.sessions.total_all_time)}</Text>
            </div>
          </Card>
        </Col>

        <Col xs={24} sm={12} lg={6}>
          <Card>
            <Statistic
              title="Participants"
              value={formatNumber(stats.stats.participants.total_all_time)}
              prefix={<TeamOutlined />}
              valueStyle={{ color: '#1890ff' }}
            />
            <div style={{ marginTop: 8 }}>
              <Text type="success">Active now: {stats.stats.participants.active_now}</Text>
            </div>
          </Card>
        </Col>
      </Row>

      {/* User Details */}
      <Row gutter={[16, 16]} style={{ marginTop: 24 }}>
        <Col xs={24} lg={12}>
          <Card title="User Overview" bordered={false}>
            <Row gutter={16}>
              <Col span={8}>
                <Statistic
                  title="Total"
                  value={stats.stats.users.total}
                  valueStyle={{ fontSize: 24 }}
                />
              </Col>
              <Col span={8}>
                <Statistic
                  title="Active"
                  value={stats.stats.users.active}
                  valueStyle={{ fontSize: 24, color: '#52c41a' }}
                />
              </Col>
              <Col span={8}>
                <Statistic
                  title="Inactive"
                  value={stats.stats.users.inactive}
                  valueStyle={{ fontSize: 24, color: '#8c8c8c' }}
                />
              </Col>
            </Row>
          </Card>
        </Col>

        <Col xs={24} lg={12}>
          <Card title="Quiz Overview" bordered={false}>
            <Row gutter={16}>
              <Col span={6}>
                <Statistic
                  title="Total"
                  value={stats.stats.quizzes.total}
                  valueStyle={{ fontSize: 24 }}
                />
              </Col>
              <Col span={6}>
                <Statistic
                  title="Ready"
                  value={stats.stats.quizzes.ready}
                  valueStyle={{ fontSize: 24, color: '#52c41a' }}
                />
              </Col>
              <Col span={6}>
                <Statistic
                  title="Draft"
                  value={stats.stats.quizzes.draft}
                  valueStyle={{ fontSize: 24, color: '#faad14' }}
                />
              </Col>
              <Col span={6}>
                <Statistic
                  title="Archived"
                  value={stats.stats.quizzes.archived}
                  valueStyle={{ fontSize: 24, color: '#8c8c8c' }}
                />
              </Col>
            </Row>
          </Card>
        </Col>
      </Row>

      {/* Session Activity */}
      <Row gutter={[16, 16]} style={{ marginTop: 24 }}>
        <Col xs={24}>
          <Card title="Session Activity" bordered={false}>
            <Row gutter={16}>
              <Col xs={24} sm={8}>
                <Statistic
                  title="Active Sessions (Right Now)"
                  value={stats.stats.sessions.active}
                  valueStyle={{ fontSize: 32, color: stats.stats.sessions.active > 0 ? '#52c41a' : '#8c8c8c' }}
                  suffix={stats.stats.sessions.active > 0 ? '🔴 LIVE' : ''}
                />
              </Col>
              <Col xs={24} sm={8}>
                <Statistic
                  title="Sessions Today"
                  value={stats.stats.sessions.total_today}
                  valueStyle={{ fontSize: 32 }}
                />
              </Col>
              <Col xs={24} sm={8}>
                <Statistic
                  title="All-Time Sessions"
                  value={formatNumber(stats.stats.sessions.total_all_time)}
                  valueStyle={{ fontSize: 32 }}
                />
              </Col>
            </Row>
          </Card>
        </Col>
      </Row>

      {/* System Load (Super Admin Only) */}
      {isSuperAdmin && stats.stats.load && (
        <Row gutter={[16, 16]} style={{ marginTop: 24 }}>
          <Col xs={24}>
            <Card title={<span><DesktopOutlined /> System Health</span>} bordered={false}>
              <Row gutter={16}>
                <Col xs={24} sm={8}>
                  <Statistic
                    title="CPU Usage"
                    value={stats.stats.load.cpu_percent}
                    suffix="%"
                    valueStyle={{
                      fontSize: 32,
                      color: getLoadColor(stats.stats.load.cpu_percent)
                    }}
                  />
                  <div style={{ marginTop: 8 }}>
                    <Text type="secondary">{getLoadStatus(stats.stats.load.cpu_percent)}</Text>
                  </div>
                </Col>
                <Col xs={24} sm={8}>
                  <Statistic
                    title="Memory Usage"
                    value={stats.stats.load.memory_percent}
                    suffix="%"
                    valueStyle={{
                      fontSize: 32,
                      color: getLoadColor(stats.stats.load.memory_percent)
                    }}
                  />
                  <div style={{ marginTop: 8 }}>
                    <Text type="secondary">{getLoadStatus(stats.stats.load.memory_percent)}</Text>
                  </div>
                </Col>
                <Col xs={24} sm={8}>
                  <Statistic
                    title="Database Connections"
                    value={stats.stats.load.db_connections}
                    valueStyle={{ fontSize: 32 }}
                  />
                  <div style={{ marginTop: 8 }}>
                    <Text type="secondary">Active connections</Text>
                  </div>
                </Col>
              </Row>
            </Card>
          </Col>
        </Row>
      )}
    </div>
  )
}

function formatNumber(num) {
  if (num >= 1000000) return (num / 1000000).toFixed(1) + 'M'
  if (num >= 1000) return (num / 1000).toFixed(1) + 'K'
  return num
}

function getLoadColor(percent) {
  if (percent > 85) return '#ff4d4f' // Red
  if (percent > 70) return '#faad14' // Orange
  return '#52c41a' // Green
}

function getLoadStatus(percent) {
  if (percent > 85) return 'High Load ⚠️'
  if (percent > 70) return 'Moderate Load'
  return 'Normal ✓'
}

export default Statistics
